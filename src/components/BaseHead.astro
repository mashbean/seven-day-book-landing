---
import {
  SITE_TITLE,
  SITE_SHORT,
  SITE_SUBTITLE,
  SITE_DESCRIPTION,
  SITE_LANG,
} from "../site.config";
import { withBase } from "../utils/paths";

interface Props {
  title?: string;
  fullTitle?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  noindex?: boolean;
}

const {
  title,
  fullTitle,
  description = SITE_DESCRIPTION,
  ogImage,
  canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
  noindex = false,
} = Astro.props;

const pageTitle =
  fullTitle ??
  (title ? `${title}｜${SITE_TITLE}` : `${SITE_SHORT}｜${SITE_SUBTITLE}`);
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<title>{pageTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

<link rel="icon" type="image/png" sizes="32x32" href={withBase("images/matters-favicon-32.png")} />
<link rel="icon" type="image/png" sizes="128x128" href={withBase("images/matters-favicon-128.png")} />
<link rel="apple-touch-icon" sizes="180x180" href={withBase("images/matters-apple-touch-icon.png")} />

<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
{ogImage && <meta property="og:image" content={new URL(withBase(ogImage), Astro.site).href} />}
<meta property="og:locale" content={SITE_LANG} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />

<!--
  Display 字型：jf-jinxuanlatte 2.1（justfont 金萱拿鐵）
  授權：matters.town 已購商用授權，repo 不含原始 OTF；只 ship subset 後 woff2
  Subset 範圍：landing source 內所有出現的中文字 + ASCII（約 1,300 chars，<300KB/weight）
  對應 spec: thematters/design-system @ docs/freewrite-design-system/typography.md
-->
<link rel="preload" href={withBase("fonts/jf-jinxuan-medium.woff2")} as="font" type="font/woff2" crossorigin />
<link rel="preload" href={withBase("fonts/jf-jinxuan-extrabold.woff2")} as="font" type="font/woff2" crossorigin />
<style is:global set:html={`
  @font-face {
    font-family: 'jf-jinxuan';
    font-style: normal;
    font-weight: 400;
    font-display: swap;
    src: url('${withBase("fonts/jf-jinxuan-book.woff2")}') format('woff2');
  }
  @font-face {
    font-family: 'jf-jinxuan';
    font-style: normal;
    font-weight: 500;
    font-display: swap;
    src: url('${withBase("fonts/jf-jinxuan-medium.woff2")}') format('woff2');
  }
  @font-face {
    font-family: 'jf-jinxuan';
    font-style: normal;
    font-weight: 700;
    font-display: swap;
    src: url('${withBase("fonts/jf-jinxuan-extrabold.woff2")}') format('woff2');
  }
  @font-face {
    font-family: 'jf-jinxuan';
    font-style: normal;
    font-weight: 900;
    font-display: swap;
    src: url('${withBase("fonts/jf-jinxuan-heavy.woff2")}') format('woff2');
  }
`}></style>
